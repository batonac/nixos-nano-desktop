#Api2
#
# Nano Desktop Sfwbar panel — classic Windows-style bottom bar.
# Launched via `sfwbar -f /etc/xdg/sfwbar/sfwbar.config`; styling is auto-loaded
# from the sibling sfwbar.css. Included *.widget files (startmenu, winops,
# volume, clock, showdesktop) are resolved from Sfwbar's bundled data dir.
# Quick-launch commands are referenced via the system profile so they survive
# updates / GC (each program must be in environment.systemPackages).

# Search path for Sfwbar's own bundled icons (open-menu, etc.)
Set ImagePath = "icons/misc"
Set ThicknessHint = "20px"

# labwc owns Alt-Tab window cycling; disable Sfwbar's own task switcher.
switcher {
  disable = true
}

# Window placer (used by Sfwbar's placement helpers)
placer {
  xorigin = 5
  yorigin = 5
  xstep = 5
  ystep = 5
  children = true
}

# Right-click-on-taskbar window operations menu
include "winops.widget"

bar {
  edge = "bottom"
  layer = "top"
  exclusive_zone = "auto"

  # Start button → freedesktop application menu (built from .desktop files)
  widget "startmenu.widget"
  widget "showdesktop.widget"

  # Quick launch
  button {
    style = "launcher"
    value = "utilities-terminal"
    tooltip = "Terminal"
    action = Exec("/run/current-system/sw/bin/foot")
  }
  button {
    style = "launcher"
    value = "web-browser"
    tooltip = "NetSurf"
    action = Exec("/run/current-system/sw/bin/netsurf-gtk3")
  }
  button {
    style = "launcher"
    value = "system-file-manager"
    tooltip = "Files"
    action = Exec("/run/current-system/sw/bin/pcmanfm")
  }

  # Open windows (wlr-foreign-toplevel)
  taskbar {
    style = "taskbar"
    rows = 1
    tooltips = true
    icons = true
    labels = true
    sort = false
    action[RightClick] = Menu("winops")
    action[Drag] = Focus()
  }

  # Elastic spacer pushing the tray/clock to the right edge
  label {
    css = "* { -GtkWidget-hexpand: true; }"
  }

  # Native PulseAudio/PipeWire volume widget (scroll to adjust, click for popup)
  widget "volume.widget" {
    simple_icon = False
    volume_thresholds = [80, 50, 0]
    volume_icons = ["audio-volume-high", "audio-volume-medium", "audio-volume-low"]
    volume_muted = "audio-volume-muted"
  }

  # SNI system tray — hosts nm-applet --indicator and blueman-applet
  tray {
    rows = 1
  }

  # Clock
  widget "clock.widget" {
    disable = false
    time_format = "%a %d %b  %H:%M"
    tooltip_format = "%H:%M%n%A, %x"
    week_starts_on_sunday = false
  }
}
