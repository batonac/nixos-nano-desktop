#Api2
#
# Nano Desktop Sfwbar panel — classic Windows-style bottom bar.
# Launched via `sfwbar -f /etc/xdg/sfwbar/sfwbar.config`; styling is auto-loaded
# from the sibling sfwbar.css. Included *.widget files (winops, volume,
# battery, network, bluez, clock) are resolved from Sfwbar's bundled data dir;
# network/bluez run as in-process modules, replacing the old resident tray
# applets (nm-applet, blueman).
# Quick-launch commands are referenced via the system profile so they survive
# updates / GC (each program must be in environment.systemPackages).

# Search path for Sfwbar's own bundled icons plus system icon themes.
# The system profile links all icon themes to /run/current-system/sw/share/icons.
# Papirus-Dark first for themed status/utility glyphs; hicolor carries each app's
# own branded icon; pixmaps + Sfwbar's bundled icons round it out.
Set ImagePath = "/run/current-system/sw/share/icons/Papirus-Dark:/run/current-system/sw/share/icons/hicolor:/run/current-system/sw/share/pixmaps:/run/current-system/sw/share/sfwbar/icons"
Set ThicknessHint = "20px"

# labwc owns Alt-Tab window cycling; disable Sfwbar's own task switcher.
switcher {
  disable = true
}

# Window placer (used by Sfwbar's placement helpers)
placer {
  xorigin = 5
  yorigin = 5
  xstep = 5
  ystep = 5
  children = true
}

# Right-click-on-taskbar window operations menu
include "winops.widget"

# Native application menu. The appmenu module enumerates the freedesktop
# .desktop files via GIO (g_app_info_get_all) and self-categorises them into
# the "app_menu_system" menu, which the Start button below opens. NOTE: GIO
# *rejects* any .desktop file whose Exec= binary is not findable in $PATH, so
# the sfwbar service must run with a real PATH (see the session services'
# `path` setting in flake.nix) — with a stripped PATH this menu renders empty.
module("appmenu")

bar {
  edge = "bottom"
  layer = "top"
  exclusive_zone = "auto"

  # Start button → the appmenu-populated application menu (module loaded above;
  # this inlines sfwbar's bundled startmenu.widget so the icon can be the NixOS
  # snowflake — `nix-snowflake` from the nixos-icons package, resolved via the
  # hicolor dir on ImagePath). The popup is painted dark by the `menu {}` rules
  # in sfwbar.css. fuzzel remains the keyboard launcher on Super+Space (see
  # labwc/rc.xml).
  button {
    style = "startmenu"
    value = "nix-snowflake"
    tooltip = "Applications"
    action = Menu("app_menu_system")
  }

  # Quick launch
  button {
    style = "launcher"
    value = "utilities-terminal"
    tooltip = "Terminal"
    action = Exec("/run/current-system/sw/bin/foot")
  }
  button {
    style = "launcher"
    value = "web-browser"
    tooltip = "Web Browser"
    action = Exec("/run/current-system/sw/bin/firefox")
  }
  button {
    style = "launcher"
    value = "system-file-manager"
    tooltip = "Files"
    action = Exec("/run/current-system/sw/bin/pcmanfm")
  }

  # Open windows (wlr-foreign-toplevel)
  taskbar {
    style = "taskbar"
    rows = 1
    tooltips = true
    icons = true
    labels = true
    sort = false
    action[RightClick] = Menu("winops")
    action[Drag] = Focus()
  }

  # Elastic spacer pushing the tray/clock to the right edge
  label {
    css = "* { -GtkWidget-hexpand: true; }"
  }

  # Native PulseAudio/PipeWire volume widget (scroll to adjust, click for popup)
  widget "volume.widget" {
    simple_icon = False
    volume_thresholds = [80, 50, 0]
    volume_icons = ["audio-volume-high", "audio-volume-medium", "audio-volume-low"]
    volume_muted = "audio-volume-muted"
  }

  # Battery status widget
  widget "battery.widget"

  # Native network status + wifi picker (network + wifi-nm modules; replaces
  # nm-applet, ~50 MB resident). The button self-hides when no interface is
  # up; the icon tracks wifi signal strength (or shows a wired glyph), the
  # tooltip lists interface/ip/gateway details, and clicking opens the wifi
  # network list with connect/disconnect/forget and a passphrase prompt.
  # nm-connection-editor stays available from the app menu for VPN/wired
  # configuration.
  widget "network.widget"

  # Native bluetooth status + pairing popup (bluez module; replaces the
  # blueman applet/tray pair, ~100 MB resident). Talks to bluetoothd
  # directly and self-hides when no adapter is present. Click lists
  # paired/available devices with pair/connect/remove; right-click gives
  # power/discoverable/scan. blueman-manager stays available from the app
  # menu (D-Bus activated on demand) for anything beyond that.
  widget "bluez.widget"

  # SNI system tray — empty by default (no resident applets anymore); hosts
  # status icons for user-launched apps that provide them.
  tray {
    rows = 1
  }

  # Clock
  widget "clock.widget" {
    disable = false
    time_format = "%a %d %b  %H:%M"
    tooltip_format = "%H:%M%n%A, %x"
    week_starts_on_sunday = false
  }
}
