# Fcitx5 global config (read from /etc/xdg/fcitx5 via XDG_CONFIG_DIRS; a
# user's ~/.config/fcitx5/config would shadow this file entirely).
#
# There is only one input method (keyboard-us, fcitx5's built-in default
# group), so every IM-switching hotkey is disabled — a bare [Hotkey/...]
# section header overrides the built-in default key list with an empty one.
# Without this, fcitx5 would grab Ctrl+Space (trigger) and Super+Space
# (group cycle) — the latter colliding with the fuzzel keybind in labwc.

[Hotkey/TriggerKeys]

[Hotkey/AltTriggerKeys]

# Candidate-list navigation for the clipboard/unicode pickers (both consult
# these global fallback lists, so the two behave identically): Up/Down move
# between candidates (fcitx default is Shift+Tab/Tab), Left/Right change
# pages (fcitx default is Up/Down — the confusing behavior this replaces).
# Page_Up/Page_Down are kept as additional paging keys.
[Hotkey/PrevCandidate]
0=Up

[Hotkey/NextCandidate]
0=Down

[Hotkey/PrevPage]
0=Left
1=Page_Up

[Hotkey/NextPage]
0=Right
1=Page_Down

[Hotkey/EnumerateForwardKeys]

[Hotkey/EnumerateBackwardKeys]

[Hotkey/EnumerateGroupForwardKeys]

[Hotkey/EnumerateGroupBackwardKeys]

[Hotkey/ActivateKeys]

[Hotkey/DeactivateKeys]

[Behavior]
ShowInputMethodInformation=False
