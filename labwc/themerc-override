# Nano Desktop labwc theme overrides — modern Adwaita DARK.
# Colours track libadwaita's dark palette (headerbar #2e2e32, window #222226,
# accent #3584e4, white text). Auto-loaded by labwc from the config directory
# passed with -C. These apply to server-side-decorated windows and the labwc
# root menu / OSD; GTK apps draw their own Adwaita-dark client-side headerbars.

# Window titlebars
window.active.title.bg.color: #2e2e32
window.active.label.text.color: #ffffff
window.active.border.color: #1c1c1f
window.inactive.title.bg.color: #242426
window.inactive.label.text.color: #9a9a9a
window.inactive.border.color: #1c1c1f

# Titlebar height — taller, to match a GNOME/Adwaita headerbar. labwc has no
# direct height key: the titlebar is (label/button height) + 2×padding.height,
# so the vertical padding is the knob. ~8px lifts it from the cramped default
# (~26px) to a comfortable ~40px.
window.titlebar.padding.height: 8
window.titlebar.padding.width: 8

# Window buttons — 24px circular targets sized to the Adwaita SVG glyphs shipped
# by the NanoAdwaita theme, with a subtle circular hover highlight (radius = half
# the button size makes it a circle, GNOME-style).
window.button.width: 24
window.button.height: 24
window.button.spacing: 4
window.button.hover.bg.color: #ffffff26
window.button.hover.bg.corner-radius: 12

# Root menu
menu.border.color: #1c1c1f
menu.items.bg.color: #2e2e32
menu.items.text.color: #ffffff
menu.items.active.bg.color: #3584e4
menu.items.active.text.color: #ffffff
menu.title.bg.color: #242226
menu.title.text.color: #ffffff
menu.separator.color: #ffffff

# On-screen display (window switcher, volume/brightness feedback)
osd.bg.color: #2e2e32
osd.label.text.color: #ffffff
osd.border.color: #1c1c1f
