<?xml version="1.0"?>
<!--
  Nano Desktop labwc configuration.

  Loaded via `labwc -C /etc/xdg/labwc` (deterministic, mirroring the old
  `jwm -f`). Executables are referenced through /run/current-system/sw/bin/
  (the system profile) rather than /nix/store/ paths, so keybinds/menu entries
  keep resolving across package updates and garbage collection. Every program
  referenced must be in environment.systemPackages so its symlink exists there.

  <default /> loads labwc's built-in keybinds (A-Tab window cycle, A-F4 close,
  A-Space window menu, W-Return terminal, W-<arrow> tiling, and the Audio /
  MonBrightness keys). The explicit binds below add the launcher, lock and
  screenshot keys, and override the volume/brightness keys to route through
  swayosd-client so they show an on-screen bar.
-->
<labwc_config>

  <theme>
    <!-- NanoAdwaita ships the GNOME/Adwaita titlebar button icons (installed to
         /share/themes/NanoAdwaita/labwc via the nano-labwc-theme package). All
         colours/sizing still come from themerc-override, loaded afterwards. -->
    <name>NanoAdwaita</name>
    <icon>Papirus-Dark</icon>
    <cornerRadius>12</cornerRadius>
    <dropShadows>yes</dropShadows>
    <!-- GNOME layout: no buttons on the left; minimize, maximize, close right. -->
    <titlebar>
      <layout>:iconify,max,close</layout>
    </titlebar>
    <font place="ActiveWindow"><name>Adwaita Sans</name><size>11</size></font>
    <font place="InactiveWindow"><name>Adwaita Sans</name><size>11</size></font>
    <font place="MenuItem"><name>Adwaita Sans</name><size>11</size></font>
    <font place="OnScreenDisplay"><name>Adwaita Sans</name><size>11</size></font>
  </theme>

  <placement>
    <policy>cascade</policy>
  </placement>

  <keyboard>
    <default />

    <!-- Launchers / run dialog (replaces JWM's gmrun on F12 / Alt-F2) -->
    <keybind key="F12"><action name="Execute" command="/run/current-system/sw/bin/fuzzel" /></keybind>
    <keybind key="A-F2"><action name="Execute" command="/run/current-system/sw/bin/fuzzel" /></keybind>
    <keybind key="W-Return"><action name="Execute" command="/run/current-system/sw/bin/foot" /></keybind>

    <!-- Screen lock (replaces slock) -->
    <keybind key="W-l"><action name="Execute" command="/run/current-system/sw/bin/swaylock" /></keybind>

    <!-- Screenshots (grim/slurp via a small wrapper; replaces maim) -->
    <keybind key="Print"><action name="Execute" command="/run/current-system/sw/bin/nano-screenshot full" /></keybind>
    <keybind key="S-Print"><action name="Execute" command="/run/current-system/sw/bin/nano-screenshot region" /></keybind>

    <!-- Volume / brightness → swayosd-client (adjusts and shows an OSD) -->
    <keybind key="XF86AudioRaiseVolume"><action name="Execute" command="/run/current-system/sw/bin/swayosd-client --output-volume raise" /></keybind>
    <keybind key="XF86AudioLowerVolume"><action name="Execute" command="/run/current-system/sw/bin/swayosd-client --output-volume lower" /></keybind>
    <keybind key="XF86AudioMute"><action name="Execute" command="/run/current-system/sw/bin/swayosd-client --output-volume mute-toggle" /></keybind>
    <keybind key="XF86AudioMicMute"><action name="Execute" command="/run/current-system/sw/bin/swayosd-client --input-volume mute-toggle" /></keybind>
    <keybind key="XF86MonBrightnessUp"><action name="Execute" command="/run/current-system/sw/bin/swayosd-client --brightness raise" /></keybind>
    <keybind key="XF86MonBrightnessDown"><action name="Execute" command="/run/current-system/sw/bin/swayosd-client --brightness lower" /></keybind>
  </keyboard>

  <libinput>
    <device category="touchpad">
      <naturalScroll>yes</naturalScroll>
      <tap>yes</tap>
    </device>
  </libinput>

</labwc_config>
